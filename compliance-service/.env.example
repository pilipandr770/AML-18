# Copy to .env and fill in. These must match the values Envoy is configured
# with (TRISA_WEBHOOK_AUTH_KEY_ID / TRISA_WEBHOOK_AUTH_KEY_SECRET), generated
# via `docker compose exec envoy.local envoy hmackey`.
WEBHOOK_AUTH_KEY_ID=
WEBHOOK_AUTH_KEY_SECRET=

# Set true only once Envoy is configured with TRISA_WEBHOOK_REQUIRE_SERVER_AUTH=true.
WEBHOOK_SIGN_REPLIES=false

# sqlite is fine for local dev outside Docker. The unified docker-compose
# stack (see ../docker-compose.yml) defaults to Postgres instead -- to
# point this local venv at that same Postgres, run `docker compose up -d
# postgres` and set DATABASE_URL=postgresql+psycopg://aml18:aml18@localhost:5432/aml18
DATABASE_URL=sqlite:////data/compliance.db

SCREENING_REVIEW_THRESHOLD=70
SCREENING_REJECT_THRESHOLD=85
SCREENING_AUTO_REJECT_EXACT_MATCH=false

# Age verification defaults. Keep `mock` for local API-only development;
# use `eu_oid4vp` when running together with the official verifier backend.
AGEVERIFY_DEFAULT_ADAPTER=mock
AGEVERIFY_MIN_AGE=18
AGEVERIFY_EU_VERIFIER_BASE_URL=
AGEVERIFY_EU_VERIFIER_TIMEOUT_SECONDS=5

# Wallet ownership verification (EBA Travel Rule guidelines / BaFin GwG
# Sec. 15a) for self-hosted-wallet transfers at or above this EUR threshold.
WALLET_OWNERSHIP_THRESHOLD_EUR=1000
WALLET_OWNERSHIP_CHALLENGE_TTL_SECONDS=600

# EVM test-transfer adapter. Leave unset to disable the test_transfer method
# (signed_message still works without these). NEVER commit a real private key.
WALLET_OWNERSHIP_EVM_RPC_URL=
WALLET_OWNERSHIP_EVM_SENDER_PRIVATE_KEY=
WALLET_OWNERSHIP_EVM_CHAIN_ID=1
WALLET_OWNERSHIP_EVM_RPC_TIMEOUT_SECONDS=10
WALLET_OWNERSHIP_TEST_TRANSFER_AMOUNT_WEI=1000000000000
WALLET_OWNERSHIP_TEST_TRANSFER_MIN_CONFIRMATIONS=1
