# Copy to .env at the repo root. Consumed by docker-compose.yml.
#
# Used to build the vendored envoy.local image (see envoy/README.md).
GIT_REVISION=

# Envoy's own webhook shared secret -- these don't exist until envoy.local
# has been started at least once. Generate via:
#   docker compose exec envoy.local envoy hmackey
# then fill in below and re-run `docker compose up -d` so both envoy.local
# and compliance.local pick up the new value. scripts/bootstrap.ps1
# automates this whole sequence.
WEBHOOK_AUTH_KEY_ID=
WEBHOOK_AUTH_KEY_SECRET=

# Set true only once Envoy is configured with TRISA_WEBHOOK_REQUIRE_SERVER_AUTH=true.
WEBHOOK_SIGN_REPLIES=false

DATABASE_URL=sqlite:////data/compliance.db

# Age verification: mock for local API-only development, eu_oid4vp for the
# full flow against the vendored EU reference verifier (default in this
# unified stack, since ageverify-verifier is always started alongside it).
AGEVERIFY_DEFAULT_ADAPTER=eu_oid4vp
AGEVERIFY_MIN_AGE=18
AGEVERIFY_EU_VERIFIER_BASE_URL=http://ageverify-verifier:8080
AGEVERIFY_EU_VERIFIER_TIMEOUT_SECONDS=5

# Wallet ownership verification (self-hosted-wallet transfers >= threshold).
# signed_message needs no further config; test_transfer stays disabled
# (AdapterNotConfiguredError) until an EVM RPC endpoint + funded sender key
# are provided here. NEVER commit a real private key.
WALLET_OWNERSHIP_THRESHOLD_EUR=1000
WALLET_OWNERSHIP_CHALLENGE_TTL_SECONDS=600
WALLET_OWNERSHIP_EVM_RPC_URL=
WALLET_OWNERSHIP_EVM_SENDER_PRIVATE_KEY=
WALLET_OWNERSHIP_EVM_CHAIN_ID=1
